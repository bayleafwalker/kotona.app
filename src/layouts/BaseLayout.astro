---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { siteConfig } from "../site";
import "../styles/global.css";

type Props = {
  title?: string;
  seoTitle?: string;
  socialTitle?: string;
  description?: string;
  noindex?: boolean;
  canonical?: boolean;
  pageType?: "website" | "article" | "profile";
  publishedDate?: Date;
  modifiedDate?: Date;
  creativeWorkStatus?: string;
  ogImage?: string;
  ogImageAlt?: string;
  breadcrumbs?: { name: string; path: string }[];
};

const {
  title,
  seoTitle,
  socialTitle,
  description = siteConfig.description,
  noindex = false,
  canonical = true,
  pageType = "website",
  publishedDate,
  modifiedDate,
  creativeWorkStatus,
  ogImage = siteConfig.defaultOgImage,
  ogImageAlt = siteConfig.defaultOgImageAlt,
  breadcrumbs = [],
} = Astro.props;

const metadataTitle = seoTitle ?? title;
const pageTitle = metadataTitle
  ? `${metadataTitle} | ${siteConfig.title}`
  : siteConfig.title;
const shareTitle = socialTitle ?? metadataTitle;
const socialPageTitle = shareTitle
  ? `${shareTitle} | ${siteConfig.title}`
  : siteConfig.title;
const canonicalUrl = new URL(Astro.url.pathname, siteConfig.siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteConfig.siteUrl).toString();
const aboutUrl = new URL("/about/", siteConfig.siteUrl).toString();
const websiteId = `${siteConfig.siteUrl}/#website`;
const schemas: Record<string, unknown>[] = [];

if (Astro.url.pathname === "/") {
  schemas.push({
    "@type": "WebSite",
    "@id": websiteId,
    url: siteConfig.siteUrl,
    name: siteConfig.title,
    description: siteConfig.description,
  });
}

if (pageType === "article") {
  schemas.push({
    "@type": "Article",
    "@id": `${canonicalUrl}#article`,
    headline: title,
    description,
    url: canonicalUrl,
    image: ogImageUrl,
    datePublished: publishedDate?.toISOString(),
    dateModified: modifiedDate?.toISOString(),
    creativeWorkStatus,
    mainEntityOfPage: { "@type": "WebPage", "@id": canonicalUrl },
    isPartOf: { "@id": websiteId },
    author: {
      "@type": "Person",
      name: siteConfig.profile.name,
      url: aboutUrl,
    },
  });
}

if (pageType === "profile") {
  schemas.push({
    "@type": "ProfilePage",
    "@id": canonicalUrl,
    url: canonicalUrl,
    name: title,
    mainEntity: {
      "@type": "Person",
      name: siteConfig.profile.name,
      url: aboutUrl,
      sameAs: [
        siteConfig.externalLinks.github,
        siteConfig.externalLinks.linkedin,
      ],
    },
  });
}

if (breadcrumbs.length > 0) {
  schemas.push({
    "@type": "BreadcrumbList",
    itemListElement: breadcrumbs.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.name,
      item: new URL(item.path, siteConfig.siteUrl).toString(),
    })),
  });
}

const structuredData =
  schemas.length > 0
    ? { "@context": "https://schema.org", "@graph": schemas }
    : null;
const cspNonce = Astro.locals.cspNonce;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f7f4ec" />
    {canonical ? <link rel="canonical" href={canonicalUrl} /> : null}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="RSS"
      href="/rss.xml"
    />
    {noindex ? <meta name="robots" content="noindex,follow" /> : null}

    <meta property="og:type" content={pageType} />
    <meta property="og:title" content={socialPageTitle} />
    <meta property="og:description" content={description} />
    {canonical ? <meta property="og:url" content={canonicalUrl} /> : null}
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:site_name" content={siteConfig.title} />
    {
      pageType === "article" && publishedDate ? (
        <meta
          property="article:published_time"
          content={publishedDate.toISOString()}
        />
      ) : null
    }
    {
      pageType === "article" && modifiedDate ? (
        <meta
          property="article:modified_time"
          content={modifiedDate.toISOString()}
        />
      ) : null
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={socialPageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    {
      structuredData ? (
        <script
          type="application/ld+json"
          is:inline
          nonce={cspNonce}
          set:html={JSON.stringify(structuredData)}
        />
      ) : null
    }
  </head>

  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <SiteHeader currentPath={Astro.url.pathname} />

    <main id="content">
      <slot />
    </main>

    <SiteFooter />
    <!-- Cloudflare Web Analytics -->
    <script
      type="module"
      is:inline
      nonce={cspNonce}
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token":"48e5fc9437d14011a3fe4346a3e1075d"}'></script>
  </body>
</html>
