---
import { getBuildRevisionLink } from "../build";
import { getContactLinks } from "../site";

const contactLinks = getContactLinks();
const buildLink = getBuildRevisionLink();
const footerLinks = [
  {
    label: "Editorial model",
    href: "/notes/the-workshop-is-learning-my-accent/",
  },
  { label: "Log", href: "/log/" },
  { label: "Privacy", href: "/privacy/" },
  { label: "RSS", href: "/rss.xml" },
  buildLink.href ? { label: buildLink.label, href: buildLink.href } : null,
  ...contactLinks,
].filter((link): link is { label: string; href: string } => Boolean(link));
---

<footer class="site-footer">
  <div class="container site-footer-inner">
    <div>
      <p class="footer-title">Read-only, small, and slightly overbuilt.</p>
      <p class="footer-copy">
        Notes arrive when the shape is clearer than the log.
      </p>
    </div>

    <ul class="footer-links" aria-label="Site and external links">
      {
        footerLinks.map((link) => (
          <li>
            <a
              href={link.href}
              rel={link.href.startsWith("http") ? "me noreferrer" : undefined}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</footer>
