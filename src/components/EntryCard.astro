---
import { formatDate } from "../lib/content";

type Props = {
  href: string;
  title: string;
  summary?: string;
  tags?: string[];
  date?: Date;
  dateLabel?: string;
  context?: string;
  headingLevel?: 2 | 3;
  draft?: boolean;
  showDate?: boolean;
};

const {
  href,
  title,
  summary,
  tags = [],
  date,
  dateLabel,
  context,
  headingLevel = 2,
  draft = false,
  showDate = true,
} = Astro.props;
const formattedDate = showDate && date ? formatDate(date) : null;
const showMeta = draft || Boolean(formattedDate);
const Heading = `h${headingLevel}` as "h2" | "h3";
---

<article class="entry-card">
  {
    showMeta ? (
      <div class="entry-meta">
        {draft ? <span class="pill pill-muted">Draft</span> : null}
        {formattedDate && date ? (
          <time class="pill" datetime={date.toISOString()}>
            {dateLabel ? `${dateLabel} ${formattedDate}` : formattedDate}
          </time>
        ) : null}
      </div>
    ) : null
  }

  <Heading class="entry-title">
    <a href={href}>{title}</a>
  </Heading>

  {context ? <p class="entry-context">{context}</p> : null}

  {summary ? <p class="entry-summary">{summary}</p> : null}

  {
    tags.length > 0 ? (
      <ul class="tag-list" aria-label="Tags">
        {tags.map((tag) => (
          <li>{tag}</li>
        ))}
      </ul>
    ) : null
  }
</article>
