---
import { formatDate } from "../lib/content";
import AnnotatedText from "./AnnotatedText.astro";
import TagList from "./TagList.astro";

type Term = {
  term: string;
  definition: string;
};

type Props = {
  href: string;
  title: string;
  summary?: string;
  tags?: string[];
  date?: Date;
  dateLabel?: string;
  context?: string;
  headingLevel?: 2 | 3;
  draft?: boolean;
  showDate?: boolean;
  terms?: Term[];
};

const {
  href,
  title,
  summary,
  tags = [],
  date,
  dateLabel,
  context,
  headingLevel = 2,
  draft = false,
  showDate = true,
  terms = [],
} = Astro.props;
const formattedDate = showDate && date ? formatDate(date) : null;
const showMeta = draft || Boolean(formattedDate);
const Heading = `h${headingLevel}` as "h2" | "h3";
---

<article class="entry-card">
  {
    showMeta ? (
      <div class="entry-meta">
        {draft ? <span class="pill pill-muted">Draft</span> : null}
        {formattedDate && date ? (
          <time class="pill" datetime={date.toISOString()}>
            {dateLabel ? `${dateLabel} ${formattedDate}` : formattedDate}
          </time>
        ) : null}
      </div>
    ) : null
  }

  <Heading class="entry-title">
    <a href={href}>{title}</a>
  </Heading>

  {context ? <p class="entry-context">{context}</p> : null}

  {
    summary ? (
      <p class="entry-summary">
        <AnnotatedText
          text={summary}
          terms={terms}
          idPrefix={`card-${href.replace(/[^a-z0-9]+/gi, "-")}`}
        />
      </p>
    ) : null
  }

  <TagList tags={tags} />
</article>
