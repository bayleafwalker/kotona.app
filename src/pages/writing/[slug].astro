---
import { getCollection, render, type CollectionEntry } from "astro:content";

import ContentToc from "../../components/ContentToc.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatDate,
  getVisibleEntries,
  sortByDateAndTitle,
} from "../../lib/content";
import { siteConfig } from "../../site";

export const prerender = true;

export async function getStaticPaths() {
  const entries = sortByDateAndTitle(await getCollection("posts"));
  const visibleEntries = getVisibleEntries(entries);

  return visibleEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

type Props = {
  entry: CollectionEntry<"posts">;
};

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const formattedDate = formatDate(entry.data.date);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.summary ?? siteConfig.description}
  noindex={entry.data.draft}
>
  <section class="content-shell">
    <article class="content-panel">
      <a class="content-back-link" href="/writing/">Back to writing</a>

      <header class="content-header">
        <p class="eyebrow">{entry.data.draft ? "Draft post" : "Post"}</p>
        <h1 class="content-title">{entry.data.title}</h1>
        {
          entry.data.summary ? (
            <p class="content-summary">{entry.data.summary}</p>
          ) : null
        }

        <div class="entry-meta">
          {entry.data.draft ? <span class="pill pill-muted">Draft</span> : null}
          <time class="pill" datetime={entry.data.date.toISOString()}>
            {formattedDate}
          </time>
        </div>

        {
          entry.data.tags.length > 0 ? (
            <ul class="tag-list" aria-label="Tags">
              {entry.data.tags.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
          ) : null
        }
      </header>

      {
        entry.data.draft ? (
          <p class="publication-note">
            This draft is visible in development and excluded from production
            builds.
          </p>
        ) : null
      }

      <div class="prose">
        <Content />
      </div>
    </article>

    <ContentToc headings={headings} />
  </section>
</BaseLayout>
