---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Not found"
  description="The page you requested does not exist."
>
  <section class="page-intro">
    <p class="eyebrow">404</p>
    <h1 class="page-title">That page is not here.</h1>
    <p class="page-copy">
      The page may have moved, or the link may be wrong. Start from the home
      page or browse the case studies and writing directly.
    </p>
    <ul class="link-row" aria-label="Helpful links">
      <li><a class="link-chip" href="/">Home</a></li>
      <li><a class="link-chip" href="/case-studies/">Case studies</a></li>
      <li><a class="link-chip" href="/writing/">Writing</a></li>
      <li><a class="link-chip" href="/about/">About</a></li>
    </ul>
  </section>
</BaseLayout>
