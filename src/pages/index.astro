---
import { getCollection } from "astro:content";

import EntryCard from "../components/EntryCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  getVisibleEntries,
  sortByDateAndTitle,
  sortByLastVerifiedAndTitle,
} from "../lib/content";
import { siteConfig } from "../site";

const projectEntries = sortByLastVerifiedAndTitle(
  await getCollection("projects"),
);
const visibleProjects = getVisibleEntries(projectEntries);
const featuredProjects = visibleProjects.filter((entry) => entry.data.featured);
const notes = sortByDateAndTitle(
  (await getCollection("notes")).map((entry) => ({
    ...entry,
    data: {
      ...entry.data,
      date: entry.data.published,
    },
  })),
);
const visibleNotes = getVisibleEntries(notes);
const startHereIds = [
  "schema-on-split",
  "moving-a-live-cluster-to-a-new-subnet",
  "judge-agents-by-the-next-prompt",
  "delivered-energy",
] as const;
const startHereNotes = startHereIds.flatMap((id) => {
  const entry = visibleNotes.find((note) => note.id === id);
  return entry ? [entry] : [];
});
const recentNotes = visibleNotes
  .filter((note) => !startHereIds.some((id) => id === note.id))
  .slice(0, 5);
---

<BaseLayout>
  <section class="intro-panel">
    <p class="eyebrow">kotona.app</p>
    <h1 class="page-title">{siteConfig.home.heading}</h1>
    <p class="page-copy">{siteConfig.home.summary}</p>
    <p class="page-copy">
      Projects explain what exists and what is currently true. Notes preserve
      decisions, boundaries, failures, and evidence worth reusing.
    </p>
  </section>

  <section class="page-section">
    <div class="section-heading">
      <h2>Start here</h2>
    </div>
    <p class="page-copy">
      Four ways into the work: data, operations, agent workflows, and applied
      exploration.
    </p>

    {
      startHereNotes.length > 0 ? (
        <div class="entry-list start-here-list">
          {startHereNotes.map((entry) => (
            <EntryCard
              href={`/notes/${entry.id}/`}
              title={entry.data.title}
              headingLevel={3}
              summary={entry.data.summary}
              context={entry.data.area}
              tags={entry.data.tags}
              date={entry.data.published}
              draft={entry.data.draft}
            />
          ))}
        </div>
      ) : null
    }
  </section>

  <section class="page-section">
    <div class="section-heading">
      <h2>Projects</h2>
      <a href="/projects/">All projects</a>
    </div>

    {
      featuredProjects.length > 0 ? (
        <div class="entry-list">
          {featuredProjects.map((entry) => (
            <EntryCard
              href={`/projects/${entry.id}/`}
              title={entry.data.title}
              headingLevel={3}
              summary={entry.data.summary}
              context={entry.data.status}
              tags={[entry.data.project, ...entry.data.tags]}
              date={entry.data.lastVerified}
              dateLabel="Verified"
              draft={entry.data.draft}
              terms={entry.data.terms}
            />
          ))}
        </div>
      ) : (
        <p class="empty-state">No published projects yet.</p>
      )
    }
  </section>

  <section class="page-section">
    <div class="section-heading">
      <h2>Recent notes</h2>
      <a href="/notes/">All notes</a>
    </div>

    {
      recentNotes.length > 0 ? (
        <div class="entry-list">
          {recentNotes.map((entry) => (
            <EntryCard
              href={`/notes/${entry.id}/`}
              title={entry.data.title}
              headingLevel={3}
              summary={entry.data.summary}
              context={entry.data.area}
              tags={entry.data.tags}
              date={entry.data.published}
              draft={entry.data.draft}
            />
          ))}
        </div>
      ) : (
        <p class="empty-state">No published notes yet.</p>
      )
    }
  </section>
</BaseLayout>
