---
import { getCollection, getEntry, render } from "astro:content";

import ContentToc from "../../components/ContentToc.astro";
import ExplorePrompt from "../../components/ExplorePrompt.astro";
import TagList from "../../components/TagList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatDate,
  getVisibleEntries,
  sortByDateAndTitle,
} from "../../lib/content";
import { generatedOgImagePath } from "../../lib/og-images.js";
import { siteConfig } from "../../site";

const id = Astro.params.slug;
const entry = id ? await getEntry("notes", id) : undefined;

if (!entry || (import.meta.env.PROD && entry.data.draft)) {
  Astro.response.status = 404;
  return Astro.rewrite("/404");
}

const { Content, headings } = await render(entry);
const formattedPublishedDate = formatDate(entry.data.published);
const wasRevised =
  entry.data.lastRevised.getTime() !== entry.data.published.getTime();
const formattedRevisedDate = formatDate(entry.data.lastRevised);
const projectEntries = getVisibleEntries(
  (
    await Promise.all(
      entry.data.projects.map((reference) => getEntry(reference)),
    )
  ).filter((project) => project !== undefined),
);
const visibleNotes = getVisibleEntries(await getCollection("notes"));
const successorNotes = getVisibleEntries(
  (
    await Promise.all(
      entry.data.supersededBy.map((reference) => getEntry(reference)),
    )
  ).filter((note) => note !== undefined),
);
const invalidatingProjects = getVisibleEntries(
  (
    await Promise.all(
      entry.data.invalidatedByProjects.map((reference) => getEntry(reference)),
    )
  ).filter((project) => project !== undefined),
);
const supersededNotes = visibleNotes.filter((note) =>
  note.data.supersededBy.some((reference) => reference.id === entry.id),
);
const explicitlyRelated = getVisibleEntries(
  (
    await Promise.all(
      entry.data.relates.map((reference) => getEntry(reference)),
    )
  ).filter((note) => note !== undefined),
);
const backlinks = visibleNotes.filter((note) =>
  note.data.relates.some((reference) => reference.id === entry.id),
);
const relatedById = new Map(
  [...explicitlyRelated, ...backlinks, ...successorNotes, ...supersededNotes]
    .filter((note) => note.id !== entry.id)
    .map((note) => [note.id, note]),
);
const relatedNotes = sortByDateAndTitle(
  [...relatedById.values()].map((note) => ({
    ...note,
    data: { ...note.data, date: note.data.published },
  })),
);
const noteKind = entry.data.draft
  ? "Draft note"
  : projectEntries.length > 0
    ? "Project note"
    : "System note";
const formattedLifecycleDate = entry.data.lifecycleChanged
  ? formatDate(entry.data.lifecycleChanged)
  : null;
const lifecycleLabel =
  entry.data.lifecycle.charAt(0).toUpperCase() + entry.data.lifecycle.slice(1);
const canonicalNoteUrl = new URL(
  `/notes/${entry.id}/`,
  siteConfig.siteUrl,
).toString();
---

<BaseLayout
  title={entry.data.title}
  seoTitle={entry.data.seoTitle}
  socialTitle={entry.data.socialTitle}
  description={entry.data.summary ?? siteConfig.description}
  noindex={entry.data.draft}
  pageType="article"
  publishedDate={entry.data.published}
  modifiedDate={entry.data.lastRevised}
  creativeWorkStatus={entry.data.lifecycle}
  ogImage={entry.data.hero?.src ?? generatedOgImagePath("notes", entry.id)}
  ogImageAlt={entry.data.hero?.alt ?? `Social card for ${entry.data.title}`}
  ogImageWidth={entry.data.hero?.width ?? 1200}
  ogImageHeight={entry.data.hero?.height ?? 630}
  breadcrumbs={[
    { name: "Home", path: "/" },
    { name: "Notes", path: "/notes/" },
    { name: entry.data.title, path: `/notes/${entry.id}/` },
  ]}
>
  <section class="content-shell">
    <article class="content-panel">
      <a class="content-back-link" href="/notes/">Back to notes</a>

      <header class="content-header">
        <p class="eyebrow">{noteKind}</p>
        <h1 class="content-title">{entry.data.title}</h1>
        {
          entry.data.summary ? (
            <p class="content-summary">{entry.data.summary}</p>
          ) : null
        }

        <div class="entry-meta note-state" aria-label="Note state">
          <span class="pill pill-accent">{entry.data.status}</span>
          <span class="pill">Role: {entry.data.role}</span>
          <span class="pill" data-lifecycle={entry.data.lifecycle}>
            Lifecycle: {entry.data.lifecycle}
          </span>
        </div>

        <p class="content-context">
          {entry.data.area} / Published {formattedPublishedDate}{
            wasRevised ? ` / Revised ${formattedRevisedDate}` : ""
          }
        </p>

        <TagList tags={entry.data.tags} />

        {
          projectEntries.length > 0 ? (
            <ul class="relation-links" aria-label="Related projects">
              {projectEntries.map((project) => (
                <li>
                  Project:{" "}
                  <a href={`/projects/${project.id}/`}>
                    {project.data.project}
                  </a>
                </li>
              ))}
            </ul>
          ) : null
        }

        {
          supersededNotes.length > 0 ? (
            <ul
              class="relation-links"
              aria-label="Notes superseded by this note"
            >
              {supersededNotes.map((note) => (
                <li>
                  Supersedes:{" "}
                  <a href={`/notes/${note.id}/`}>{note.data.title}</a>
                </li>
              ))}
            </ul>
          ) : null
        }
      </header>

      {
        entry.data.hero ? (
          <figure class="content-hero">
            <img
              src={entry.data.hero.src}
              alt={entry.data.hero.alt}
              width={entry.data.hero.width}
              height={entry.data.hero.height}
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
            {entry.data.hero.caption ? (
              <figcaption>{entry.data.hero.caption}</figcaption>
            ) : null}
          </figure>
        ) : null
      }

      {
        entry.data.lifecycle !== "current" ? (
          <aside
            class="publication-note lifecycle-note"
            aria-label="Note lifecycle"
          >
            <p>
              <strong>{lifecycleLabel}</strong>
              {formattedLifecycleDate
                ? ` ${formattedLifecycleDate}.`
                : "."}{" "}
              {entry.data.lifecycleReason}
            </p>
            {successorNotes.length > 0 ? (
              <ul>
                {successorNotes.map((note) => (
                  <li>
                    Successor:{" "}
                    <a href={`/notes/${note.id}/`}>{note.data.title}</a>
                  </li>
                ))}
              </ul>
            ) : null}
            {invalidatingProjects.length > 0 ? (
              <ul>
                {invalidatingProjects.map((project) => (
                  <li>
                    Invalidated by project state:{" "}
                    <a href={`/projects/${project.id}/`}>
                      {project.data.project}
                    </a>
                  </li>
                ))}
              </ul>
            ) : null}
          </aside>
        ) : null
      }

      {
        entry.data.explorePrompt ? (
          <ExplorePrompt
            prompt={entry.data.explorePrompt}
            sourceUrl={canonicalNoteUrl}
            kind="note"
          />
        ) : null
      }

      <ContentToc headings={headings} />

      {
        entry.data.draft ? (
          <p class="publication-note">
            This draft is visible in development and is not published in
            production.
          </p>
        ) : null
      }

      <div class="prose">
        <Content />
      </div>

      {
        relatedNotes.length > 0 ? (
          <nav class="related-content" aria-labelledby="related-notes-title">
            <h2 id="related-notes-title">Related notes</h2>
            <ul>
              {relatedNotes.map((note) => (
                <li>
                  <a href={`/notes/${note.id}/`}>{note.data.title}</a>
                </li>
              ))}
            </ul>
          </nav>
        ) : null
      }
    </article>
  </section>
</BaseLayout>
