---
import { getCollection, getEntry, render } from "astro:content";

import ContentToc from "../../components/ContentToc.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatDate,
  getVisibleEntries,
  sortByDateAndTitle,
} from "../../lib/content";
import { siteConfig } from "../../site";

const id = Astro.params.slug;
const entry = id ? await getEntry("notes", id) : undefined;

if (!entry || (import.meta.env.PROD && entry.data.draft)) {
  Astro.response.status = 404;
  return Astro.rewrite("/404");
}

const { Content, headings } = await render(entry);
const formattedPublishedDate = formatDate(entry.data.published);
const wasRevised =
  entry.data.lastRevised.getTime() !== entry.data.published.getTime();
const formattedRevisedDate = formatDate(entry.data.lastRevised);
const projectEntries = getVisibleEntries(
  (
    await Promise.all(
      entry.data.projects.map((reference) => getEntry(reference)),
    )
  ).filter((project) => project !== undefined),
);
const visibleNotes = getVisibleEntries(await getCollection("notes"));
const explicitlyRelated = getVisibleEntries(
  (
    await Promise.all(
      entry.data.relates.map((reference) => getEntry(reference)),
    )
  ).filter((note) => note !== undefined),
);
const backlinks = visibleNotes.filter((note) =>
  note.data.relates.some((reference) => reference.id === entry.id),
);
const relatedById = new Map(
  [...explicitlyRelated, ...backlinks]
    .filter((note) => note.id !== entry.id)
    .map((note) => [note.id, note]),
);
const relatedNotes = sortByDateAndTitle(
  [...relatedById.values()].map((note) => ({
    ...note,
    data: { ...note.data, date: note.data.published },
  })),
);
const noteKind = entry.data.draft
  ? "Draft note"
  : projectEntries.length > 0
    ? "Project note"
    : "System note";
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.summary ?? siteConfig.description}
  noindex={entry.data.draft}
  pageType="article"
  publishedDate={entry.data.published}
  modifiedDate={entry.data.lastRevised}
>
  <section class="content-shell">
    <article class="content-panel">
      <a class="content-back-link" href="/notes/">Back to notes</a>

      <header class="content-header">
        <p class="eyebrow">{noteKind}</p>
        <h1 class="content-title">{entry.data.title}</h1>
        {
          entry.data.summary ? (
            <p class="content-summary">{entry.data.summary}</p>
          ) : null
        }

        <p class="content-context">
          {entry.data.status} / {entry.data.area} / Published {
            formattedPublishedDate
          }{wasRevised ? ` / Revised ${formattedRevisedDate}` : ""}
        </p>

        {
          projectEntries.length > 0 ? (
            <ul class="relation-links" aria-label="Related projects">
              {projectEntries.map((project) => (
                <li>
                  Project:{" "}
                  <a href={`/projects/${project.id}/`}>
                    {project.data.project}
                  </a>
                </li>
              ))}
            </ul>
          ) : null
        }
      </header>

      <ContentToc headings={headings} />

      {
        entry.data.draft ? (
          <p class="publication-note">
            This draft is visible in development and is not published in
            production.
          </p>
        ) : null
      }

      <div class="prose">
        <Content />
      </div>

      {
        relatedNotes.length > 0 ? (
          <nav class="related-content" aria-labelledby="related-notes-title">
            <h2 id="related-notes-title">Related notes</h2>
            <ul>
              {relatedNotes.map((note) => (
                <li>
                  <a href={`/notes/${note.id}/`}>{note.data.title}</a>
                </li>
              ))}
            </ul>
          </nav>
        ) : null
      }
    </article>
  </section>
</BaseLayout>
