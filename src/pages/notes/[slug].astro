---
import { getCollection, render, type CollectionEntry } from "astro:content";

import ContentToc from "../../components/ContentToc.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatDate,
  getVisibleEntries,
  sortByDateAndTitle,
} from "../../lib/content";
import { siteConfig } from "../../site";

export const prerender = true;

export async function getStaticPaths() {
  const entries = sortByDateAndTitle(
    (await getCollection("notes")).map((entry) => ({
      ...entry,
      data: {
        ...entry.data,
        date: entry.data.lastRevised,
      },
    })),
  );
  const visibleEntries = getVisibleEntries(entries);

  return visibleEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

type Props = {
  entry: CollectionEntry<"notes">;
};

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const formattedDate = formatDate(entry.data.lastRevised);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.summary ?? siteConfig.description}
  noindex={entry.data.draft}
>
  <section class="content-shell">
    <article class="content-panel">
      <a class="content-back-link" href="/notes/">Back to notes</a>

      <header class="content-header">
        <p class="eyebrow">{entry.data.draft ? "Draft note" : "System note"}</p>
        <h1 class="content-title">{entry.data.title}</h1>
        {
          entry.data.summary ? (
            <p class="content-summary">{entry.data.summary}</p>
          ) : null
        }

        <p class="content-context">
          {entry.data.status} / {entry.data.area} / Revised {formattedDate}
        </p>

        {
          entry.data.relates.length > 0 ? (
            <ul class="tag-list" aria-label="Related notes">
              {entry.data.relates.map((slug) => (
                <li>
                  <a href={`/notes/${slug}/`}>{slug}</a>
                </li>
              ))}
            </ul>
          ) : null
        }
      </header>

      <ContentToc headings={headings} />

      {
        entry.data.draft ? (
          <p class="publication-note">
            This draft is visible in development and excluded from production
            builds.
          </p>
        ) : null
      }

      <div class="prose">
        <Content />
      </div>
    </article>
  </section>
</BaseLayout>
