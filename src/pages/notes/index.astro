---
import { getCollection } from "astro:content";

import EntryCard from "../../components/EntryCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getVisibleEntries, sortByDateAndTitle } from "../../lib/content";

const notes = sortByDateAndTitle(
  (await getCollection("notes")).map((entry) => ({
    ...entry,
    data: {
      ...entry.data,
      date: entry.data.published,
    },
  })),
);
const visibleNotes = getVisibleEntries(notes);
---

<BaseLayout
  title="Notes"
  description="Project notes and system notes in reverse chronological order."
>
  <section class="page-intro">
    <p class="eyebrow">Notes</p>
    <h1 class="page-title">Project notes and system notes.</h1>
    <p class="page-copy">
      Operating rules, synthesis, bounded explorations, and project history.
      Role selects the note's register; claim posture says how strongly it is
      held, and lifecycle says whether it remains current.
    </p>
  </section>

  <section class="page-section">
    {
      visibleNotes.length > 0 ? (
        <div class="entry-list">
          {visibleNotes.map((entry) => (
            <EntryCard
              href={`/notes/${entry.id}/`}
              title={entry.data.title}
              summary={entry.data.summary}
              context={`${entry.data.role} / ${entry.data.status} / ${entry.data.lifecycle} / ${entry.data.area}`}
              tags={entry.data.tags}
              date={entry.data.published}
              draft={entry.data.draft}
            />
          ))}
        </div>
      ) : (
        <p class="empty-state">No published notes yet.</p>
      )
    }
  </section>
</BaseLayout>
