---
import { getCollection } from "astro:content";

import BaseLayout from "../layouts/BaseLayout.astro";
import { formatDate, getVisibleEntries } from "../lib/content";
import changelog from "../data/changelog.json";

type ChangelogEntry = { date: string; entry: string; href?: string };
const notes = getVisibleEntries(await getCollection("notes"));
const projects = getVisibleEntries(await getCollection("projects"));
const generatedEntries: ChangelogEntry[] = [
  ...notes.map((note) => ({
    date: note.data.published.toISOString().slice(0, 10),
    entry: `Published note: ${note.data.title}.`,
    href: `/notes/${note.slug}/`,
  })),
  ...projects.map((project) => ({
    date: project.data.lastVerified.toISOString().slice(0, 10),
    entry: `Verified project state: ${project.data.project}.`,
    href: `/projects/${project.slug}/`,
  })),
];
const entries = [...(changelog as ChangelogEntry[]), ...generatedEntries]
  .sort(
    (left, right) =>
      new Date(right.date).getTime() - new Date(left.date).getTime() ||
      left.entry.localeCompare(right.entry),
  )
  .map((item) => ({
    ...item,
    formattedDate: formatDate(new Date(item.date)),
  }));
---

<BaseLayout
  title="Log"
  description="Chronological record of site changes and project state transitions."
>
  <section class="page-intro">
    <p class="eyebrow">Log</p>
    <h1 class="page-title">Publication and project log</h1>
    <p class="page-copy">
      Published notes and verified project states are generated from content
      metadata. Site-level changes remain a small manual record.
    </p>
  </section>

  <section class="page-section">
    <ol class="changelog-list" reversed>
      {
        entries.map((item) => (
          <li class="changelog-entry">
            <time class="changelog-date" datetime={item.date}>
              {item.formattedDate}
            </time>
            <span class="changelog-text">
              {item.href ? <a href={item.href}>{item.entry}</a> : item.entry}
            </span>
          </li>
        ))
      }
    </ol>
  </section>
</BaseLayout>
