---
import { getCollection } from "astro:content";

import EntryCard from "../../components/EntryCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getVisibleEntries, sortByDateAndTitle } from "../../lib/content";

export const prerender = true;

const allProjects = sortByDateAndTitle(await getCollection("projects"));
const visibleProjects = getVisibleEntries(allProjects);

const engineering = visibleProjects.filter(
  (entry) => entry.data.kind === "engineering" && !entry.data.draft,
);
const fiction = visibleProjects.filter(
  (entry) => entry.data.kind === "fiction" && !entry.data.draft,
);
const drafts = import.meta.env.PROD
  ? []
  : visibleProjects.filter((entry) => entry.data.draft);
---

<BaseLayout
  title="Projects"
  description="Project summaries — repositories and worlds — described plainly."
>
  <section class="page-intro">
    <p class="eyebrow">Projects</p>
    <h1 class="page-title">Bounded efforts with declared state.</h1>
    <p class="page-copy">
      Each page is a stable summary of a project: what it does, how it is
      shaped, and what state the work is in. Some are repositories, some are
      worlds. The shell is the same.
    </p>
  </section>

  {
    engineering.length > 0 ? (
      <section class="page-section">
        <div class="section-heading">
          <h2>Repositories</h2>
        </div>

        <div class="entry-list">
          {engineering.map((entry) => (
            <EntryCard
              href={`/projects/${entry.slug}/`}
              title={entry.data.title}
              summary={entry.data.summary}
              tags={entry.data.tags}
              draft={entry.data.draft}
              showDate={false}
            />
          ))}
        </div>
      </section>
    ) : null
  }

  {
    fiction.length > 0 ? (
      <section class="page-section">
        <div class="section-heading">
          <h2>Worlds</h2>
        </div>

        <div class="entry-list">
          {fiction.map((entry) => (
            <EntryCard
              href={`/projects/${entry.slug}/`}
              title={entry.data.title}
              summary={entry.data.summary}
              tags={entry.data.tags}
              draft={entry.data.draft}
              showDate={false}
            />
          ))}
        </div>
      </section>
    ) : null
  }

  {
    drafts.length > 0 ? (
      <section class="page-section">
        <div class="section-heading">
          <h2>Drafts</h2>
        </div>

        <div class="entry-list">
          {drafts.map((entry) => (
            <EntryCard
              href={`/projects/${entry.slug}/`}
              title={entry.data.title}
              summary={entry.data.summary}
              tags={entry.data.tags}
              draft={entry.data.draft}
              showDate={false}
            />
          ))}
        </div>
      </section>
    ) : null
  }
</BaseLayout>
