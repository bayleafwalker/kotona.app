---
import { getCollection, render, type CollectionEntry } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import { getVisibleEntries, sortByDateAndTitle } from "../../lib/content";

export const prerender = true;

export async function getStaticPaths() {
  const entries = sortByDateAndTitle(await getCollection("projects"));
  const visibleEntries = getVisibleEntries(entries);

  return visibleEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

type Props = {
  entry: CollectionEntry<"projects">;
};

const { entry } = Astro.props;
const { Content } = await render(entry);
const repoLinks = entry.data.repoUrls.map((href, i) => ({
  label: entry.data.repoUrls.length === 1 ? "Repository" : `Repository ${i + 1}`,
  href,
}));
const relatedLinks = [
  ...repoLinks,
  entry.data.externalUrl
    ? { label: "External link", href: entry.data.externalUrl }
    : null,
].filter((link): link is { label: string; href: string } => Boolean(link));
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.summary}
  noindex={entry.data.draft}
>
  <section class="content-shell project-shell">
    <article class="content-panel project-panel">
      <a class="content-back-link" href="/projects/">Back to projects</a>

      <header class="content-header">
        <p class="eyebrow">Project</p>
        <h1 class="content-title">{entry.data.title}</h1>
        <p class="content-summary">{entry.data.summary}</p>

        <div class="entry-meta">
          {entry.data.draft ? <span class="pill pill-muted">Draft</span> : null}
          {
            entry.data.status ? (
              <span class="pill pill-accent">{entry.data.status}</span>
            ) : null
          }
        </div>

        <ul class="tag-list" aria-label="Tags">
          {entry.data.tags.map((tag) => <li>{tag}</li>)}
        </ul>

        {
          relatedLinks.length > 0 ? (
            <ul class="link-row" aria-label="Related links">
              {relatedLinks.map((link) => (
                <li>
                  <a class="link-chip" href={link.href} rel="noreferrer">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          ) : null
        }
      </header>

      {
        entry.data.draft ? (
          <p class="draft-note">
            This project page is still a draft. Replace placeholders with a
            clear overview, a concrete system shape, current state, and open
            edges before treating it as finished.
          </p>
        ) : null
      }

      <div class="prose">
        <Content />
      </div>
    </article>
  </section>
</BaseLayout>
