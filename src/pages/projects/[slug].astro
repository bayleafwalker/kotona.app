---
import { getCollection, getEntry, render } from "astro:content";

import ContentToc from "../../components/ContentToc.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatDate,
  getVisibleEntries,
  sortByDateAndTitle,
} from "../../lib/content";

const slug = Astro.params.slug;
const entry = slug ? await getEntry("projects", slug) : undefined;

if (!entry || (import.meta.env.PROD && entry.data.draft)) {
  Astro.response.status = 404;
  return Astro.rewrite("/404");
}

const { Content, headings } = await render(entry);
const formattedPublishedDate = formatDate(entry.data.published);
const formattedRevisedDate = formatDate(entry.data.lastRevised);
const formattedVerifiedDate = formatDate(entry.data.lastVerified);
const relatedNotes = sortByDateAndTitle(
  getVisibleEntries(await getCollection("notes"))
    .filter((note) =>
      note.data.projects.some((reference) => reference.id === entry.slug),
    )
    .map((note) => ({
      ...note,
      data: { ...note.data, date: note.data.published },
    })),
);
const repoLinks = entry.data.repoUrls.map((href) => {
  const pathname = new URL(href).pathname;
  const repositoryName = pathname.split("/").filter(Boolean).at(-1);

  return {
    label: repositoryName ? `Repository: ${repositoryName}` : "Repository",
    href,
  };
});
const relatedLinks = [
  ...repoLinks,
  entry.data.externalUrl
    ? { label: "External link", href: entry.data.externalUrl }
    : null,
].filter((link): link is { label: string; href: string } => Boolean(link));
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.summary}
  noindex={entry.data.draft}
  pageType="article"
  publishedDate={entry.data.published}
  modifiedDate={entry.data.lastRevised}
>
  <section class="content-shell project-shell">
    <article class="content-panel project-panel">
      <a class="content-back-link" href="/projects/">Back to projects</a>

      <header class="content-header">
        <p class="eyebrow">Project / {entry.data.project}</p>
        <h1 class="content-title">{entry.data.title}</h1>
        <p class="content-summary">{entry.data.summary}</p>

        <div class="entry-meta">
          {entry.data.draft ? <span class="pill pill-muted">Draft</span> : null}
          {
            entry.data.status ? (
              <span class="pill pill-accent">{entry.data.status}</span>
            ) : null
          }
        </div>

        <p class="content-context">
          Published {formattedPublishedDate} / Revised {formattedRevisedDate} / Verified
          {formattedVerifiedDate}
        </p>

        <ul class="tag-list" aria-label="Tags">
          {entry.data.tags.map((tag) => <li>{tag}</li>)}
        </ul>

        {
          relatedLinks.length > 0 ? (
            <ul class="link-row" aria-label="Related links">
              {relatedLinks.map((link) => (
                <li>
                  <a class="link-chip" href={link.href} rel="noreferrer">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          ) : null
        }
      </header>

      {
        entry.data.draft ? (
          <p class="draft-note">
            This project page is still a draft. Replace placeholders with a
            clear overview, a concrete system shape, current state, and open
            edges before treating it as finished.
          </p>
        ) : null
      }

      <ContentToc headings={headings} />

      <div class="prose">
        <Content />
      </div>

      {
        relatedNotes.length > 0 ? (
          <nav class="related-content" aria-labelledby="project-notes-title">
            <h2 id="project-notes-title">Notes from this project</h2>
            <ul>
              {relatedNotes.map((note) => (
                <li>
                  <a href={`/notes/${note.slug}/`}>{note.data.title}</a>
                </li>
              ))}
            </ul>
          </nav>
        ) : null
      }
    </article>
  </section>
</BaseLayout>
