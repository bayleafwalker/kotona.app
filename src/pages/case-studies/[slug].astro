---
import { getCollection, render, type CollectionEntry } from "astro:content";

import ContentToc from "../../components/ContentToc.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatDate,
  getVisibleEntries,
  sortByDateAndTitle,
} from "../../lib/content";

export const prerender = true;

export async function getStaticPaths() {
  const entries = sortByDateAndTitle(await getCollection("case-studies"));
  const visibleEntries = getVisibleEntries(entries);

  return visibleEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

type Props = {
  entry: CollectionEntry<"case-studies">;
};

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const formattedDate = formatDate(entry.data.date);
const relatedLinks = [
  entry.data.repoUrl ? { label: "Repository", href: entry.data.repoUrl } : null,
  entry.data.externalUrl
    ? { label: "External link", href: entry.data.externalUrl }
    : null,
].filter((link): link is { label: string; href: string } => Boolean(link));
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.summary}
  noindex={entry.data.draft}
>
  <section class="content-shell">
    <article class="content-panel">
      <a class="content-back-link" href="/case-studies/">Back to case studies</a
      >

      <header class="content-header">
        <p class="eyebrow">Case study</p>
        <h1 class="content-title">{entry.data.title}</h1>
        <p class="content-summary">{entry.data.summary}</p>

        <div class="entry-meta">
          {entry.data.draft ? <span class="pill pill-muted">Draft</span> : null}
          {
            entry.data.status ? (
              <span class="pill pill-accent">{entry.data.status}</span>
            ) : null
          }
          {formattedDate ? <span class="pill">{formattedDate}</span> : null}
        </div>

        <ul class="tag-list" aria-label="Tags">
          {entry.data.tags.map((tag) => <li>{tag}</li>)}
        </ul>

        {
          relatedLinks.length > 0 ? (
            <ul class="link-row" aria-label="Related links">
              {relatedLinks.map((link) => (
                <li>
                  <a class="link-chip" href={link.href} rel="noreferrer">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          ) : null
        }
      </header>

      {
        entry.data.draft ? (
          <p class="draft-note">
            This page is a draft scaffold. Replace the TODO markers with
            specific facts, implementation details, and validation evidence
            before treating it as a finished portfolio piece.
          </p>
        ) : null
      }

      <div class="prose">
        <Content />
      </div>
    </article>

    <ContentToc headings={headings} />
  </section>
</BaseLayout>
