{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "kotona-app",
  "main": "./dist/_worker.js/index.js",
  "compatibility_date": "2026-04-08",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "preview_urls": true,
  "observability": {
    "enabled": true,
  },
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "50bfc5aa99b64e638a6350bced0f9a63",
    },
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
  },
}
