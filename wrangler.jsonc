{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "kotona-app",
  "main": "./dist/_worker.js/index.js",
  "compatibility_date": "2026-04-08",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "preview_urls": true,
  "routes": [
    {
      "pattern": "www.kotona.app",
      "custom_domain": true,
    },
  ],
  "observability": {
    "enabled": true,
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
  },
}
