{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "kotona-app",
  "main": "./dist/_worker.js/index.js",
  "compatibility_date": "2026-04-09",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "preview_urls": true,
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [{ "binding": "SESSION" }],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  }
}