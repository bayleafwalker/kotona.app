{
  "name": "kotona-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <23"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && printf '_worker.js\n' > dist/.assetsignore && wrangler deploy",
    "cf-typegen": "wrangler types",
    "check": "astro check",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "validate": "npm run format && npm run lint && npm run check && npm run build"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.0",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.6.0",
    "astro": "^5.7.12"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^12.6.13",
    "@eslint/js": "^9.25.1",
    "@types/node": "^22.15.18",
    "eslint": "^9.25.1",
    "eslint-plugin-astro": "^1.3.1",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "wrangler": "^4.81.0"
  }
}
