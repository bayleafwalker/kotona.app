{
  "name": "kotona-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "predev": "npm run generate:og",
    "dev": "astro dev",
    "prebuild": "npm run generate:og",
    "build": "astro build",
    "preview": "npm run build && astro preview",
    "deploy": "npm run build && wrangler deploy",
    "audit:dependencies": "npm audit --audit-level=moderate",
    "cf-typegen": "wrangler types",
    "check": "astro check",
    "check:content-freshness": "node scripts/check-project-freshness.mjs",
    "check:explore-prompts": "node scripts/check-explore-prompts.mjs",
    "check:links": "node scripts/check-external-links.mjs",
    "lint": "eslint .",
    "test": "node --test tests/*.test.mjs",
    "test:worker": "node scripts/worker-smoke.mjs",
    "test:retrieval": "node scripts/retrieval-eval.mjs",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "generate:og": "node scripts/generate-og-images.mjs",
    "validate": "npm run format && npm run lint && npm test && npm run audit:dependencies && npm run check:content-freshness && npm run check:explore-prompts && npm run check && npm run build && npm run test:worker && npm run test:retrieval && npm run check:links",
    "prepare": "git rev-parse --git-dir > /dev/null 2>&1 && git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.1.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^14.1.4",
    "@eslint/js": "^9.25.1",
    "@types/node": "^24.0.0",
    "eslint": "^9.25.1",
    "eslint-plugin-astro": "^1.3.1",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.35.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "wrangler": "^4.110.0",
    "yaml": "^2.9.0"
  },
  "overrides": {
    "sharp": "$sharp"
  }
}
